{
  "name": "deskpet",
  "version": "0.1.0",
  "description": "陪伴你、会去旅行、会寄明信片的桌面宠物狗",
  "main": "main.js",
  "scripts": {
    "postinstall": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ node node_modules/electron/install.js",
    "start": "electron .",
    "start:dev": "cross-env DESKPET_DEV=1 electron .",
    "make-icon": "node scripts/make-icon.js",
    "reset-travel": "node scripts/reset-travel.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test \"tests/unit/*.test.js\"",
    "test:e2e": "playwright test",
    "dist": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win nsis",
    "dist:mac": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac",
    "dist:dir": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thompsoncn/deskPet.git"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "windows"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Thompsoncn/deskPet/issues"
  },
  "homepage": "https://github.com/Thompsoncn/deskPet#readme",
  "build": {
    "appId": "com.deskpet.app",
    "productName": "deskPet",
    "copyright": "Copyright © 2026 deskPet",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/**/*",
      "data/**/*",
      "!**/*.md",
      "!**/.DS_Store"
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "deskPet",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
